{
  "name": "c-trend-live",
  "version": "1.0.0",
  "description": "A browser VJ rig for the world's webcams — a GPU Rutt/Etra synthesizer with Syphon output.",
  "author": "Yufeng Zhao",
  "license": "MIT",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server.js",
    "electron:dev": "ELECTRON_RENDERER_URL=http://localhost:3000 electron electron/main.cjs",
    "electron:start": "vite build && electron electron/main.cjs",
    "electron:spike": "electron electron/spike.cjs",
    "dist:mac": "vite build && electron-builder --mac dmg --arm64"
  },
  "dependencies": {
    "express": "^5.2.1",
    "http-proxy-middleware": "^3.0.5"
  },
  "optionalDependencies": {
    "node-syphon": "^1.5.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.0",
    "@preact/signals": "^2.0.1",
    "@tweakpane/core": "^2.0.5",
    "@types/three": "^0.172.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "hls.js": "^1.5.0",
    "postprocessing": "^6.37.0",
    "preact": "^10.25.0",
    "three": "^0.172.0",
    "tweakpane": "^4.0.5",
    "typescript": "^5.7.0",
    "vite": "^6.3.1",
    "vite-plugin-glsl": "^1.3.1"
  },
  "trustedDependencies": [
    "node-syphon"
  ]
}
